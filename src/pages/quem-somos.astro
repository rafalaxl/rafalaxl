---
// src/pages/quem-somos.astro
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import { Image } from 'astro:assets';
import devBoutiqueImg from '../../assets/images/desenvolvimento_boutique.webp';

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Sobre a NECXUS",
  "description": "Apresentação de posicionamento da NECXUS como desenvolvedor solo focado em qualidade técnica boutique e proximidade com o cliente.",
  "url": "https://necxus.com.br/quem-somos",
  "mainEntity": {
    "@type": "Person",
    "name": "Rafael",
    "jobTitle": "Engenheiro de Software & Desenvolvedor Web Solo",
    "worksFor": {
      "@type": "Organization",
      "name": "NECXUS"
    }
  }
};
---

<Layout
  title="Quem Somos | NECXUS e o Modelo de Desenvolvimento Boutique"
  description="Conheça o Rafael, o desenvolvedor solo por trás da NECXUS. Transparência, engenharia limpa e proximidade extrema para acelerar a captação digital do seu negócio."
  ogTitle="NECXUS | Desenvolvimento Boutique com o Rafael"
  ogDescription="Descubra por que trabalhar diretamente com quem escreve o código do seu site gera resultados melhores do que lidar com a estrutura pesada de uma agência tradicional."
  schema={aboutSchema}
>
  <!-- Hero Section -->
  <section class="relative py-20 overflow-hidden bg-base">
    <div class="max-w-7xl mx-auto px-4 md:px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="flex flex-col gap-6">
        <h1 class="text-4xl md:text-6xl font-display font-bold text-primary tracking-tight leading-tight">
          A Pessoa por Trás do Seu Código
        </h1>
        <h2 class="text-lg md:text-xl text-secondary leading-relaxed font-body">
          Por que trabalhar com um desenvolvedor solo focado em excelência técnica é o maior atalho para o crescimento digital do seu negócio local.
        </h2>
      </div>
      <div class="relative flex justify-center items-center">
        <!-- Elemento gráfico abstrato representando conexão -->
        <div class="w-72 h-72 rounded-full bg-gradient-to-tr from-accent-primary/20 to-accent-secondary/20 blur-3xl absolute animate-pulse"></div>
        <div class="w-64 h-64 border border-white/10 rounded-2xl bg-surface/50 backdrop-blur-sm p-6 flex flex-col justify-between relative">
          <div class="w-12 h-12 rounded-lg bg-accent-primary/20 flex items-center justify-center border border-accent-primary/30 text-accent-primary font-bold text-lg">
            N
          </div>
          <div class="text-muted text-xs font-mono uppercase tracking-wider">
            Nexo + Tecnologia
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- História e Propósito -->
  <section class="py-20 border-t border-white/5 bg-surface/30">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center max-w-7xl mx-auto px-4 md:px-8">
      <div class="flex flex-col gap-6">
        <h2 class="text-3xl md:text-4xl font-display font-semibold text-primary tracking-tight">
          O Fim da Burocracia corporativa
        </h2>
        <div class="prose prose-invert max-w-none text-secondary space-y-6 text-base md:text-lg leading-relaxed">
          <p>
            A <strong class="text-primary">NECXUS</strong> nasceu de um descontentamento claro com o mercado tradicional de desenvolvimento web. Durante anos, vi proprietários de clínicas, estúdios de tatuagem e academias pagarem caro por sites que eram apenas cópias de templates prontos do WordPress — pesados, instáveis e lentos.
          </p>
          <p>
            Pior do que o produto final era o processo de comunicação. No modelo de agência convencional, para que uma simples mudança fosse feita no seu site, você precisava passar por um comercial, falar com um gerente de contas, abrir um ticket técnico e aguardar dias até que um programador terceirizado recebesse o chamado com ruídos de comunicação.
          </p>
          <p>
            Eu decidi fazer diferente. Fundei a <strong class="text-primary">NECXUS</strong> sob a premissa do <strong class="text-primary">desenvolvimento boutique</strong>. Isso significa que você tem acesso direto a mim, o engenheiro responsável pelo seu projeto. Não terceirizo a criação. Cada linha de HTML, CSS e JavaScript que compõe o seu site é escrita diretamente por mim, focada em segurança, SEO e velocidade de carregamento real.
          </p>
          <p>
            O nome da marca vem de <strong class="text-primary">Nexo</strong> — a união lógica, a coerência entre o que o seu negócio é na vida real e como ele é representado no mundo digital. Unimos a solidez técnica de engenharia de software à sensibilidade de vendas que o seu negócio precisa para atrair e reter clientes reais.
          </p>
        </div>
      </div>
      <div class="relative overflow-hidden rounded-2xl border border-white/10 shadow-2xl">
        <Image
          src={devBoutiqueImg}
          alt="Desenvolvimento Boutique com tecnologia de ponta e proximidade extrema"
          width={600}
          height={400}
          format="webp"
          class="w-full h-auto object-cover hover:scale-105 transition-transform duration-500"
        />
      </div>
    </div>
  </section>

  <!-- Manifesto de Valores -->
  <section class="py-24 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <h2 class="text-3xl md:text-4xl font-display font-semibold text-primary tracking-tight mb-16 text-center">
        Nossas Diretrizes de Trabalho
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Valor 1 -->
        <div class="bg-surface border border-white/10 p-8 rounded-2xl flex flex-col gap-4">
          <div class="w-12 h-12 rounded-lg bg-accent-primary/10 border border-accent-primary/20 flex items-center justify-center text-accent-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-medium text-primary">1. Transparência Absoluta</h3>
          <p class="text-secondary text-sm leading-relaxed">
            Sem termos difíceis para esconder falhas de desempenho. Explicamos detalhadamente cada pilar técnico de forma simples. Você é o dono real do código do seu site. Se decidir migrar no futuro, seu código estará limpo, estruturado e sob seu domínio completo.
          </p>
        </div>

        <!-- Valor 2 -->
        <div class="bg-surface border border-white/10 p-8 rounded-2xl flex flex-col gap-4">
          <div class="w-12 h-12 rounded-lg bg-accent-secondary/10 border border-accent-secondary/20 flex items-center justify-center text-accent-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-medium text-primary">2. Código Sob Medida</h3>
          <p class="text-secondary text-sm leading-relaxed">
            Rejeitamos a mediocridade de arrastar e soltar elementos visuais pesados. Cada site é planejado a partir de uma estrutura enxuta, garantindo que o tempo de carregamento não dependa de servidores caros. Menos scripts, mais resultados de velocidade.
          </p>
        </div>

        <!-- Valor 3 -->
        <div class="bg-surface border border-white/10 p-8 rounded-2xl flex flex-col gap-4">
          <div class="w-12 h-12 rounded-lg bg-status-success/10 border border-status-success/20 flex items-center justify-center text-status-success">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-medium text-primary">3. Foco em Conversão Real</h3>
          <p class="text-secondary text-sm leading-relaxed">
            Um site que recebe mil visitas e nenhum clique no WhatsApp é apenas um painel inútil. Criamos jornadas de usuário que direcionam o visitante para a ação principal: o contato direto com a sua equipe comercial.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <Cta />
</Layout>
