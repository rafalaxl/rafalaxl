---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Problemas from '../components/Problemas.astro';
import Servicos from '../components/Servicos.astro';
import Portfolio from '../components/Portfolio.astro';
import Cta from '../components/Cta.astro';

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "NECXUS",
  "image": "https://necxus.com.br/assets/images/logo.webp",
  "description": "Desenvolvimento de sites profissionais, landing pages de alta conversão e funis de captação digital sob medida para PMEs e negócios locais.",
  "url": "https://necxus.com.br",
  "telephone": "+5515997047914",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "São Paulo",
    "addressRegion": "SP",
    "addressCountry": "BR"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "opens": "09:00",
    "closes": "18:00"
  }
};
---

<Layout 
	title="NECXUS | Sites Ultrarrápidos e Páginas de Alta Conversão para PMEs" 
	description="Esqueça templates lentos e agências burocráticas. Desenvolvemos sites institucionais e landing pages sob medida focados em captar leads e vender direto no WhatsApp."
	image="/assets/images/home-share.webp"
	ogTitle="NECXUS | Desenvolvimento Web sob Medida e Sem Intermediários"
	ogDescription="Descubra o impacto de um site desenvolvido com código puro (Astro e Next.js) que carrega instantaneamente no celular do seu cliente."
	schema={homeSchema}
>
	<Hero />
	<Problemas />
	<Servicos />
	<Portfolio />
	<Cta />
</Layout>
