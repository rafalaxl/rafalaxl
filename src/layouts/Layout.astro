---
// src/layouts/Layout.astro
interface Props {
	title: string;
	description: string;
	image?: string;
	canonicalURL?: string | URL;
}

const { 
	title, 
	description, 
	image = '/og-image.jpg',
	canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url)
} = Astro.props;

import '../styles/global.css';

const siteUrl = Astro.site ? Astro.site.toString() : "https://necxus.com.br";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "NECXUS",
  "description": "Desenvolvimento sob medida para negócios locais. Sites institucionais e Landing Pages focados em captação via WhatsApp.",
  "url": siteUrl,
  "logo": new URL('/favicon.svg', siteUrl).toString(),
  "image": new URL(image, siteUrl).toString(),
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "BR"
  },
  "offers": {
    "@type": "AggregateOffer",
    "offerCount": "3",
    "itemOffered": [
      {
        "@type": "Service",
        "name": "Landing Pages de Alta Performance"
      },
      {
        "@type": "Service",
        "name": "Posicionamento Orgânico e SEO Local"
      },
      {
        "@type": "Service",
        "name": "Funil Direto de WhatsApp"
      }
    ]
  }
};
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, canonicalURL)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, canonicalURL)} />

		<!-- Schema.org JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-base text-primary font-body antialiased min-h-screen flex flex-col">
		<header class="fixed top-0 w-full z-50 bg-white/5 backdrop-blur-lg border-b border-white/10">
			<div class="max-w-7xl mx-auto px-4 md:px-8 h-20 flex items-center justify-between">
				<a href="/" class="text-2xl font-display font-bold text-primary tracking-tight">NECXUS</a>
				<nav class="hidden md:flex gap-8">
					<a href="#servicos" class="text-sm font-medium text-secondary hover:text-primary transition-colors">Serviços</a>
					<a href="#portfolio" class="text-sm font-medium text-secondary hover:text-primary transition-colors">Portfólio</a>
				</nav>
				<a href="#contato" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-accent-primary text-white text-sm font-medium hover:scale-105 hover:shadow-[0_0_20px_rgba(59,130,246,0.5)] transition-all duration-300">
					Falar no WhatsApp
				</a>
			</div>
		</header>

		<main class="flex-grow pt-20">
			<slot />
		</main>

		<footer class="bg-base border-t border-white/10 py-12 mt-24">
			<div class="max-w-7xl mx-auto px-4 md:px-8 text-center flex flex-col items-center gap-6">
				<p class="text-muted text-sm max-w-md">
					NECXUS © 2026. Código sob medida para negócios que não aceitam a lentidão como padrão.
				</p>
				<div class="flex gap-4 text-sm text-muted">
					<a href="/politica-de-privacidade" class="hover:text-primary transition-colors">Política de Privacidade</a>
					<a href="/termos-de-uso" class="hover:text-primary transition-colors">Termos de Uso</a>
				</div>
			</div>
		</footer>
	</body>
</html>
