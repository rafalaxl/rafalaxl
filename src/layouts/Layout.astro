---
// src/layouts/Layout.astro
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string | URL;
  schema?: Record<string, any>;
  ogTitle?: string;
  ogDescription?: string;
}

const { 
  title, 
  description, 
  image = '/assets/images/home-share.webp',
  canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url),
  schema,
  ogTitle,
  ogDescription
} = Astro.props;

const finalOgTitle = ogTitle || title;
const finalOgDescription = ogDescription || description;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={finalOgTitle} />
    <meta property="og:description" content={finalOgDescription} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={finalOgTitle} />
    <meta property="twitter:description" content={finalOgDescription} />
    <meta property="twitter:image" content={new URL(image, canonicalURL)} />

    <!-- Schema.org JSON-LD -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-base text-primary font-body antialiased min-h-screen flex flex-col pt-20">
    <Navbar />

    <main class="flex-grow">
      <slot />
    </main>

    <Footer />
    <ChatWidget />
  </body>
</html>

